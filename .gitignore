# Godot 4+ specific ignores
.godot/
/android/

# Exported builds (regenerable via Project → Export)
# Ignore artifacts but keep the .gdignore so Godot doesn't auto-import build outputs.
/builds/*
!/builds/.gdignore

# macOS
.DS_Store

# Claude / superpowers workspace (local-only; don't publish)
.claude/
.superpowers/
CLAUDE.md

# Local design scratch (specs + plans live outside the public repo)
docs/superpowers/

# Local-only frozen reference docs
docs/animation-authoring-guide.html
docs/blender-character-handoff.md

# Editor / OS scratch
*.log
*.tmp
*.bak
*.orig
*~
.*.swp

# IDE workspace state (machine-specific)
.idea/
.vscode/
