# Godot 4+ specific ignores
.godot/
/android/

# Exported builds (regenerable via Project → Export)
# Ignore artifacts but keep the .gdignore so Godot doesn't auto-import build outputs.
/builds/*
!/builds/.gdignore

# macOS
.DS_Store

# Claude / superpowers ephemeral state
.claude/settings.local.json
.superpowers/
